FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(h|e)"
    {
        solver           PCG;
        preconditioner   DIC;
        tolerance        1e-06;
        relTol           0.1;
    }

    "(h|e)Final"
    {
        $h;
        relTol           0;
    }
}

PIMPLE
{
    nOuterCorrectors 1;
    nNonOrthogonalCorrectors 2;
}

relaxationFactors
{
    equations
    {
        "h.*"           1;
        "e.*"           1;
    }
}

