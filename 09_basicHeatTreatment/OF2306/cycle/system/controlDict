FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     solidFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         600;

deltaT          0.005;

writeControl    runTime;

writeInterval   5;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep      yes;

maxDi             10;  // Número de difusión máximo (equivalente al Co para calor)
maxDeltaT         0.5;     // Límite superior absoluto para el paso de tiempo

// ************************************************************************* //

functions
{
    averageT
    {
        // Mandatory entries
        type            volFieldValue;
        libs            (fieldFunctionObjects);
        operation       average;
        fields          (T);
        writeFields     false;
        cellZone        all;

        // Optional entries
        writeControl    timeStep;
        writeInterval   10;
        writeToFile     true;    
    }

    minT
    {
        // Mandatory entries
        type            volFieldValue;
        libs            (fieldFunctionObjects);
        operation       min;
        fields          (T);
        writeFields     false;
        cellZone        all;

        // Optional entries
        writeControl    timeStep;
        writeInterval   10;
        writeToFile     true;  
    }

    maxT
    {
        // Mandatory entries
        type            volFieldValue;
        libs            (fieldFunctionObjects);
        operation       max;
        fields          (T);
        writeFields     false;
        cellZone        all;

        // Optional entries
        writeControl    timeStep;
        writeInterval   10;
        writeToFile     true;  
    }
}