FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles      1;
        molWeight   56; // [kg/kmol]
    }

    transport
    {
        kappa   40;    // [W/m/K]
    }

    thermodynamics
    {
        Hf      0;
        Cp      577;    // [J/kg/K]
    }

    equationOfState
    {
        rho     7686;   // [kg/m^3]
    }
}

