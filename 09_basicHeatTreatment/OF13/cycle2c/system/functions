FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      functions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *
averageT
{
    // Mandatory entries
    type            volFieldValue;
    libs            ("libfieldFunctionObjects.so");
    operation       average;
    fields          (T);
    writeFields     false;
    cellZone        all;

    // Optional entries
    writeControl    timeStep;
    writeInterval   2;
    writeToFile     true;    
}

