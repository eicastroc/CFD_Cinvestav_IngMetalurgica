FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     foamRun;

solver          solid;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         600;

deltaT          0.005;

writeControl    runTime;

writeInterval   5;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep      yes;

maxDi             0.5;  // Número de difusión máximo (equivalente al Co para calor)
maxDeltaT         0.5;     // Límite superior absoluto para el paso de tiempo

